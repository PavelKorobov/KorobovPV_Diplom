//{{ Коробов П.В. Задание: Заполнение Реализации товаров и услуг
Функция ПечатьАктаОказанияУслуг(МассивОбъектов, ОбъектыПечати)

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_АктОказанияУслуг";
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.РеализацияТоваровУслуг.ПФ_MXL_АктОказанияУслуг");
	
	ДанныеДокументов = ПолучитьДанныеДокументов(МассивОбъектов);
	
	ПервыйДокумент = Истина;
	
	Пока ДанныеДокументов.Следующий() Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ВывестиЗаголовокАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет);
		
		ВывестиШапкуАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет);
	
		ВывестиТаблицуАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет);
		
		ВывестиПодвалАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет);
		
		ВывестиИсполнительАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет);
		
		ВывестиЗаказчикАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
		НомерСтрокиНачало, ОбъектыПечати, ДанныеДокументов.Ссылка);		
		
	КонецЦикла;	
	
	Возврат ТабличныйДокумент;
	
КонецФункции
//}} Коробов П.В. Задание: Заполнение Реализации товаров и услуг

//{{ Коробов П.В. Задание: Заполнение Реализации товаров и услуг
Процедура ВывестиЗаголовокАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет)
	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("ОбластьЗаголовок");
	
	ОбластьЗаголовок.Параметры.Номер = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ДанныеДокументов.Номер);
	ОбластьЗаголовок.Параметры.Дата = Формат(ДанныеДокументов.Дата, "ДФ=dd.MM.yyyy;");
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	
КонецПроцедуры
//}} Коробов П.В. Задание: Заполнение Реализации товаров и услуг

//{{ Коробов П.В. Задание: Заполнение Реализации товаров и услуг
Процедура ВывестиШапкуАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет)
	
	ОбластьШапка = Макет.ПолучитьОбласть("ОбластьШапка");
	
	ОбластьШапка.Параметры.Организация = ДанныеДокументов.Организация;
	ОбластьШапка.Параметры.Контрагент = ДанныеДокументов.Контрагент;
	ОбластьШапка.Параметры.Договор = ДанныеДокументов.Договор;
	
	ТабличныйДокумент.Вывести(ОбластьШапка);
	
КонецПроцедуры
//}} Коробов П.В. Задание: Заполнение Реализации товаров и услуг

//{{ Коробов П.В. Задание: Заполнение Реализации товаров и услуг
Процедура ВывестиТаблицуАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет)
	
	ОбластьТаблица = Макет.ПолучитьОбласть("ОбластьТаблица");
	
	ВыборкаТабличнаяЧасть = ДанныеДокументов.Услуги.Выбрать();
	
	Пока ВыборкаТабличнаяЧасть.Следующий() Цикл
		
		ОбластьТаблица.Параметры.НомерСтроки = ВыборкаТабличнаяЧасть.НомерСтроки;
		ОбластьТаблица.Параметры.Услуги = ВыборкаТабличнаяЧасть.Номенклатура;
		ОбластьТаблица.Параметры.Количество = ВыборкаТабличнаяЧасть.Количество;
		ОбластьТаблица.Параметры.Цена = ВыборкаТабличнаяЧасть.Цена;
		ОбластьТаблица.Параметры.Сумма = ВыборкаТабличнаяЧасть.Сумма;
		
		ТабличныйДокумент.Вывести(ОбластьТаблица);
		
	КонецЦикла;
	
КонецПроцедуры
//}} Коробов П.В. Задание: Заполнение Реализации товаров и услуг

//{{ Коробов П.В. Задание: Заполнение Реализации товаров и услуг
Процедура ВывестиПодвалАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет)
	
	ОбластьПодвал = Макет.ПолучитьОбласть("ОбластьПодвал");
	
	ВыборкаТабличнаяЧасть = ДанныеДокументов.Услуги.Выбрать();
	ОбластьПодвал.Параметры.ЧислоНаименований = ВыборкаТабличнаяЧасть.Количество();
	СуммаИтого = 0;
	
	Пока ВыборкаТабличнаяЧасть.Следующий() Цикл
		СуммаИтого = СуммаИтого + ВыборкаТабличнаяЧасть.Сумма;
	КонецЦикла;
	
	ОбластьПодвал.Параметры.СуммаИтого = СуммаИтого;
	ОбластьПодвал.Параметры.СуммаПрописью = ЧислоПрописью(СуммаИтого, , "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
	
	ТабличныйДокумент.Вывести(ОбластьПодвал);
	
КонецПроцедуры
//}} Коробов П.В. Задание: Заполнение Реализации товаров и услуг

//{{ Коробов П.В. Задание: Заполнение Реализации товаров и услуг
Процедура ВывестиИсполнительАктаОказанияУслуг(ДанныеДокументов, ТабличныйДокумент, Макет)
	
	ОбластьИсполнитель = Макет.ПолучитьОбласть("ОбластьИсполнитель");
	
